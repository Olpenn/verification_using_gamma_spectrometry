#=====================================================
# GEOMETRY
#=====================================================
/gate/geometry/setMaterialDatabase /software/gate/src/GateMaterials.db
/gate/world/setMaterial AirBodyInterface
/gate/world/geometry/setXLength 1 m
/gate/world/geometry/setYLength 1 m
/gate/world/geometry/setZLength 1 m

# Simple phantom (where U-235 sits)
/gate/world/daughters/name phantom
/gate/world/daughters/insert box
/gate/phantom/setMaterial Water
/gate/phantom/geometry/setXLength 10 cm
/gate/phantom/geometry/setYLength 10 cm
/gate/phantom/geometry/setZLength 10 cm

#=====================================================
# PHYSICS
#=====================================================
/gate/physics/addPhysicsList QGSP_BERT_EMV
/gate/physics/addProcess RadioactiveDecay
/gate/run/initialize

#=====================================================
# SOURCE - URANIUM-235
#=====================================================
/gate/source/addSource u235
/gate/source/u235/setActivity 10000 becquerel
/gate/source/u235/gps/particle ion
/gate/source/u235/gps/ion 92 235 0 0
/gate/source/u235/gps/energy 0 eV
/gate/source/u235/setForcedUnstableFlag true
/gate/source/u235/useDefaultHalfLife
/gate/source/u235/gps/type Point
/gate/source/u235/gps/centre 0 0 0 cm
/gate/source/u235/gps/angtype iso

#=====================================================
# KILL ACTOR - STOP Pa-231 FROM DECAYING FURTHER
#=====================================================
/gate/actor/addActor KillActor killPa231
/gate/actor/killPa231/attachTo phantom
/gate/actor/killPa231/addFilter particleFilter
/gate/actor/killPa231/particleFilter/addParticleZ 91
/gate/actor/killPa231/particleFilter/addParticleA 231

#=====================================================
# SIMULATION CONTROL
#=====================================================
/gate/application/setTotalNumberOfPrimaries 1000
/gate/application/start
exit